# ============================================================================
# Multi-Agent Framework (with Memory) — Environment Configuration
#
# INSTRUCTIONS:
#   1. cp .env.example .env
#   2. Fill in your workspace values
#   3. Configure agents.yaml (cp agents.example.yaml agents.yaml)
#   4. Deploy: databricks bundle deploy && databricks bundle run multiagent_app
# ============================================================================

# ── REQUIRED: Databricks Auth ───────────────────────────────────────────────
DATABRICKS_CONFIG_PROFILE=DEFAULT

# ── REQUIRED: Warehouse (for UC function execution) ─────────────────────────
DATABRICKS_WAREHOUSE_ID=

# ── OPTIONAL: Used in agents.yaml via ${VAR_NAME} syntax ────────────────────
UC_CATALOG=
UC_SCHEMA=
GENIE_SPACE_ID=
COMPANY_NAME=Multi-Agent Assistant

# ── MEMORY: Lakebase Configuration ──────────────────────────────────────────
# Both short-term and long-term memory use Lakebase. Set ONE of the options:
#
# Option 1: Provisioned Lakebase instance
# LAKEBASE_INSTANCE_NAME=my-lakebase-instance
#
# Option 2: Autoscaling Lakebase (serverless)
# LAKEBASE_AUTOSCALING_PROJECT=my-project
# LAKEBASE_AUTOSCALING_BRANCH=main
#
# If NEITHER is set, memory is disabled and the framework works without it.
#
# Long-term memory embedding model (default: databricks-gte-large-en)
# EMBEDDING_ENDPOINT=databricks-gte-large-en
# EMBEDDING_DIMS=1024

# ── MLflow (auto-configured) ────────────────────────────────────────────────
MLFLOW_EXPERIMENT_ID=
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"

# ── Frontend ────────────────────────────────────────────────────────────────
CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
